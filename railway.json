{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksVersion": "1.41.0",
    "nixpacksConfig": {
      "providers": ["node"],
      "nodejs": {
        "nodeVersion": "20"
      }
    }
  },
  "deploy": {
    "startCommand": "node dist/boot.js",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
